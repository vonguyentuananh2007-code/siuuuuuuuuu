<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Luyện Phát Âm Tiếng Trung</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        .card { border: 1px solid #ccc; padding: 20px; border-radius: 10px; width: 300px; text-align: center; }
        .hanzi { font-size: 3em; margin: 10px 0; color: #d32f2f; }
        .pinyin { font-size: 1.5em; color: #555; margin-bottom: 20px; }
        button { padding: 10px 20px; cursor: pointer; background: #4caf50; color: white; border: none; border-radius: 5px; }
    </style>
</head>
<body>

    <h2>Luyện phát âm</h2>
    <div class="card">
        <div class="hanzi" id="hanzi">你好</div>
        <div class="pinyin" id="pinyin">nǐ hǎo</div>
        <button onclick="speak()">Nghe phát âm</button>
    </div>

    <script>
        function speak() {
            const text = document.getElementById('hanzi').innerText;
            const utterance = new SpeechSynthesisUtterance(text);
            // Thiết lập ngôn ngữ là Tiếng Trung (Phổ thông)
            utterance.lang = 'zh-CN'; 
            window.speechSynthesis.speak(utterance);
        }
    </script>
</body>
</html>
